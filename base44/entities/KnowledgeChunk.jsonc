{
  "name": "KnowledgeChunk",
  "type": "object",
  "description": "Base de conocimiento vectorial nativa FinLogic. Cada registro es un chunk de normativa chilena con su embedding sem\u00e1ntico para b\u00fasqueda por similitud coseno (estilo Pinecone, sin dependencia externa).",
  "properties": {
    "module": {
      "type": "string",
      "enum": [
        "ley_fintech_21521",
        "ncg_502_cmf",
        "ley_19496_sernac",
        "ley_20555",
        "ley_21719_datos",
        "ley_20009_fraude",
        "ley_21663_ciberseguridad",
        "lir_propyme",
        "ley_21713_tributaria",
        "tributacion_cripto",
        "open_finance",
        "csirt",
        "general"
      ],
      "description": "M\u00f3dulo normativo al que pertenece el chunk"
    },
    "regulatoryBody": {
      "type": "string",
      "enum": [
        "CMF",
        "SERNAC",
        "SII",
        "CSIRT",
        "BCN",
        "FOGAPE",
        "SERCOTEC",
        "multiple"
      ],
      "description": "Organismo regulador competente"
    },
    "title": {
      "type": "string",
      "description": "T\u00edtulo del chunk, ej: 'Ley 20.009 Art. 5\u00b0 \u2014 Carga de la prueba en fraude'"
    },
    "content": {
      "type": "string",
      "description": "Contenido textual del chunk (200-800 tokens recomendado)"
    },
    "lawReference": {
      "type": "string",
      "description": "Referencia legal precisa, ej: 'Ley 20.009 Art. 5\u00b0' o 'NCG 502 CMF Art. 15'"
    },
    "embedding": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "description": "Vector embedding (1536 dims OpenAI ada-002 compatible) para b\u00fasqueda sem\u00e1ntica"
    },
    "embeddingModel": {
      "type": "string",
      "default": "text-embedding-3-small",
      "description": "Modelo usado para generar el embedding"
    },
    "tokens": {
      "type": "number",
      "description": "Cantidad aproximada de tokens del chunk"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags para filtrado adicional, ej: ['plazo_legal', 'fraude_tarjeta']"
    },
    "sourceUrl": {
      "type": "string",
      "description": "URL oficial de la fuente (leychile.cl, sernac.cl, etc.)"
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Si el chunk est\u00e1 vigente y usable en b\u00fasquedas"
    }
  },
  "required": [
    "module",
    "title",
    "content",
    "lawReference"
  ],
  "rls": {
    "read": {},
    "write": {
      "user_condition": {
        "role": {
          "$eq": "admin"
        }
      }
    }
  }
}