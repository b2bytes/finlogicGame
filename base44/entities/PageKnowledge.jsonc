{
  "name": "PageKnowledge",
  "type": "object",
  "description": "Base de conocimiento estructurada de cada p\u00e1gina/secci\u00f3n de la plataforma FinLogic. Permite a Lya (agente de voz) descubrir contenido din\u00e1micamente v\u00eda b\u00fasqueda sem\u00e1ntica + keywords. Cada registro es vectorizable en Pinecone.",
  "properties": {
    "path": {
      "type": "string",
      "description": "Ruta de la p\u00e1gina, ej: '/PitchDeck' o '/Consulta'. PK l\u00f3gica."
    },
    "name": {
      "type": "string",
      "description": "Nombre legible para el agente, ej: 'Pitch Deck' o 'Equipo'"
    },
    "title": {
      "type": "string",
      "description": "T\u00edtulo principal de la p\u00e1gina (h1)"
    },
    "summary": {
      "type": "string",
      "description": "Resumen 1-2 p\u00e1rrafos de qu\u00e9 hay en la p\u00e1gina, escrito para que el LLM entienda su prop\u00f3sito y cu\u00e1ndo derivar a ella."
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Palabras y frases clave para matching r\u00e1pido (ej: 'equipo', 'fundadores', 'paula garces')"
    },
    "segment": {
      "type": "string",
      "enum": [
        "b2c",
        "b2b",
        "pyme",
        "concurso",
        "interno",
        "demo",
        "marca",
        "general"
      ],
      "default": "general",
      "description": "Segmento al que pertenece la p\u00e1gina"
    },
    "audience": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "camila",
          "don_luis",
          "maria_jose",
          "roberto",
          "jurado",
          "fintech",
          "prensa",
          "general"
        ]
      },
      "default": [
        "general"
      ],
      "description": "Arquetipos / p\u00fablicos para los que la p\u00e1gina es relevante"
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "id HTML del anchor, ej: 'slide-equipo'"
          },
          "label": {
            "type": "string",
            "description": "Nombre humano de la secci\u00f3n"
          },
          "summary": {
            "type": "string",
            "description": "Resumen 1 l\u00ednea"
          }
        }
      },
      "description": "Secciones internas (anchors) de la p\u00e1gina, scrollables por Lya"
    },
    "ctas": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "description": "valor data-lya-action del CTA"
          },
          "label": {
            "type": "string",
            "description": "Qu\u00e9 hace ese CTA"
          }
        }
      },
      "description": "CTAs interactivos disponibles en la p\u00e1gina, marcados con data-lya-action"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags transversales: 'urgente', 'concurso', 'normativa', etc."
    },
    "priority": {
      "type": "number",
      "default": 50,
      "description": "0-100 \u2014 sirve para ordenar en respuestas ambiguas"
    },
    "vectorId": {
      "type": "string",
      "description": "ID del vector en Pinecone si fue indexado"
    },
    "lastIndexedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "path",
    "name",
    "summary"
  ],
  "rls": {
    "read": {},
    "write": {
      "user_condition": {
        "role": {
          "$eq": "admin"
        }
      }
    }
  }
}