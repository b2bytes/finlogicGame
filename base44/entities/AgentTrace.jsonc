{
  "name": "AgentTrace",
  "type": "object",
  "description": "Auditor\u00eda completa del pipeline IA. Habilita la p\u00e1gina /Transparencia donde el ciudadano ve c\u00f3mo el sistema lleg\u00f3 a su respuesta. Diferenciador competitivo central de FinLogic.",
  "properties": {
    "sessionId": {
      "type": "string",
      "description": "ID de sesi\u00f3n de conversaci\u00f3n"
    },
    "casoRef": {
      "type": "string",
      "description": "Reference \u2192 MisCasos si el trace gener\u00f3 un caso"
    },
    "query": {
      "type": "string",
      "description": "Consulta original del ciudadano"
    },
    "category": {
      "type": "string",
      "enum": [
        "fraude_digital",
        "cobro_indebido",
        "derechos_arco",
        "contrato_abusivo",
        "normativa_consulta",
        "indicadores_economicos",
        "compliance_api",
        "fuera_de_scope"
      ],
      "description": "Categor\u00eda detectada por triage"
    },
    "pipelineStage": {
      "type": "string",
      "enum": [
        "triage",
        "tools_live",
        "rag_search",
        "specialist",
        "verifier",
        "complete"
      ],
      "description": "Etapa del pipeline secuencial"
    },
    "triageLatencyMs": {
      "type": "number",
      "description": "Latencia triage GPT-5 mini, target <600ms"
    },
    "ragLatencyMs": {
      "type": "number",
      "description": "Latencia RAG sobre Knowledge Files"
    },
    "specialistLatencyMs": {
      "type": "number",
      "description": "Latencia Claude Sonnet 4.6 especialista"
    },
    "totalLatencyMs": {
      "type": "number",
      "description": "Latencia total del pipeline"
    },
    "verifierScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Score del verificador. Baseline 72/100, target 85/100 en 90 d\u00edas"
    },
    "lawsCited": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Leyes y normativa citada en la respuesta"
    },
    "toolsUsed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "checkUsury",
          "checkCmfAlerts",
          "cmfBankInfo",
          "getEconomicIndicators",
          "checkFraudAlerts"
        ]
      },
      "description": "Herramientas en vivo ejecutadas"
    },
    "responsePreview": {
      "type": "string",
      "description": "Primeros 200 chars de la respuesta para auditor\u00eda"
    },
    "citizenSummary": {
      "type": "string",
      "description": "Resumen en lenguaje simple para Vista Ciudadano de /Transparencia"
    },
    "modelUsed": {
      "type": "string",
      "enum": [
        "sonnet",
        "opus",
        "haiku",
        "gpt-5-mini"
      ],
      "description": "Modelo principal usado en la respuesta"
    },
    "tokensConsumed": {
      "type": "number",
      "description": "Tokens consumidos en la consulta"
    },
    "isPublic": {
      "type": "boolean",
      "default": true,
      "description": "Si aparece en /Transparencia p\u00fablico"
    }
  },
  "required": [
    "query",
    "category",
    "pipelineStage"
  ],
  "rls": {
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": {
              "$eq": "admin"
            }
          }
        },
        {
          "isPublic": {
            "$eq": true
          }
        },
        {
          "created_by": "{{user.email}}"
        }
      ]
    },
    "write": {
      "user_condition": {
        "role": {
          "$eq": "admin"
        }
      }
    }
  }
}